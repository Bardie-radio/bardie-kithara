{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "DbProvider": "sqlite",
  "DbConnectionString": "Data Source=kithara.db",
  "ModuleChannel": {
    "UseMtls": true,
    "BootstrapMode": "Auto",
    "TlsDataPath": "data/mtls",
    "ServerDnsNames": [ "kithara", "localhost" ]
  },
  "ModuleRegistry": {
    "HeartbeatTtl": "00:01:30",
    "NextHeartbeatAfterSeconds": 30
  },
  "BlobStorage": {
    "Driver": "local",
    "Path": "data/blobs"
  },
  "Neck": {
    "StrunaFifoRoot": "data/struna-fifos",
    "Mp3BitrateKbps": 128
  },
  "BARDIE_JOIN_SECRETS": "{\"dummy\":\"dummy-join-secret\",\"bes\":\"bes-join-secret\",\"magpie\":\"magpie-join-secret\"}"
}
