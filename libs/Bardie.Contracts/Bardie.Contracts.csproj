<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <RootNamespace>Bardie.Contracts</RootNamespace>
    <AssemblyName>Bardie.Contracts</AssemblyName>
    <IsPackable>true</IsPackable>
    <PackageId>Bardie.Contracts</PackageId>
    <Version>0.1.0</Version>
    <Description>Versioned gRPC contract package for Bardie module authors (ModuleRegistry, AuthAdapter).</Description>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Google.Protobuf" />
    <PackageReference Include="Grpc.AspNetCore" />
    <PackageReference Include="Grpc.Net.Client" />
    <PackageReference Include="Grpc.Tools">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup>
    <Protobuf Include="Protos\module_registry.proto" GrpcServices="Both" />
    <Protobuf Include="Protos\auth_adapter.proto" GrpcServices="Both" />
  </ItemGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
    <Content Include="Protos\**\*.proto" Pack="true" PackagePath="protos/%(RecursiveDir)%(Filename)%(Extension)" />
  </ItemGroup>

</Project>
